# LLM (OpenRouter via pydantic-ai)
# Get your key at https://openrouter.ai/keys
MODEL_NAME=openrouter/google/gemini-2.0-flash-001
OPENROUTER_API_KEY=

# Observability backends (defaults work with local OTel demo + Loki sidecar)
JAEGER_URL=http://localhost:8080/jaeger/ui
JAEGER_AUTH=
LOKI_URL=http://localhost:3100
LOKI_AUTH=

# GitHub MCP (read-only PAT — maps to GITHUB_PERSONAL_ACCESS_TOKEN in MCP)
GITHUB_TOKEN=

# Optional capabilities
E2B_API_KEY=

# Logfire observability (https://logfire.pydantic.dev)
# Leave unset to log to console only (no Logfire account needed for local dev)
LOGFIRE_TOKEN=

# Logging
LOG_LEVEL=INFO

# Optional tuning (defaults shown — usually leave unset)
# MAX_TOOL_CALLS=10
# STOP_CONFIDENCE=0.85
# RETRY_CONFIDENCE=0.4
# FASTPATH_CONFIDENCE=0.9
# JAEGER_DEFAULT_URL=http://localhost:8080/jaeger/ui
# LOKI_DEFAULT_URL=http://localhost:3100

# Not env vars — provide in setup chat per session:
# repo: open-telemetry/opentelemetry-demo
# service_name: ad
